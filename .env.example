# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=code_context
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth / Security ---
JWT_SECRET=changeme-use-a-long-random-string
JWT_EXPIRY_HOURS=24
CREDENTIAL_ENCRYPTION_KEY=

# --- GitHub ---
GITHUB_API_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=

# --- Embedding ---
EMBEDDING_MODEL=bge-small-en
EMBEDDING_DIM=384

# --- App ---
API_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=INFO
DEBUG=false
CLONE_BASE_DIR=/tmp/ticket-to-prompt-repos
